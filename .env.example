ACC_ENVIRONMENT=development
ACC_HOST=127.0.0.1
# To expose through host-network Docker on a trusted LAN, use the host's private IP:
# ACC_HOST=192.168.88.9
ACC_PORT=8000
# Docker Compose process identity; set these to the output of `id -u` and `id -g`.
# ACC_UID=1000
# ACC_GID=1000
ACC_DATA_DIR=data
ACC_DATABASE_URL=sqlite:///data/app.db
ACC_OPENAI_API_KEY=
ACC_OPENAI_MODEL=gpt-5.6-luna
ACC_OPENAI_TIMEOUT_SECONDS=60
ACC_AZURE_SPEECH_KEY=
ACC_AZURE_SPEECH_REGION=eastasia
ACC_AZURE_SPEECH_LOCALE=en-US
ACC_AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural
ACC_AZURE_SPEECH_OUTPUT_FORMAT=audio-24khz-96kbitrate-mono-mp3
ACC_AZURE_SPEECH_RATE=-8%
ACC_AZURE_SPEECH_CONFIG_VERSION=1
ACC_ANKI_CONNECT_URL=http://127.0.0.1:8765
ACC_ANKI_CONNECT_TIMEOUT_SECONDS=10
ACC_ANKI_DECK=Anki Custom Card
ACC_WORKER_ENABLED=true
ACC_WORKER_POLL_SECONDS=1
ACC_WORKER_LEASE_SECONDS=120
